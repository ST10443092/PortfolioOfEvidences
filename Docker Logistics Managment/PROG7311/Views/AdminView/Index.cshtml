@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Admin Dashboard</h1>
        <p class="page-subtitle">Overview and management access for key logistics modules.</p>
    </div>
</div>

<div class="dashboard-grid">
    <div class="dashboard-card">
        <h5>Clients</h5>
        <p>View and manage client profiles.</p>
        <a asp-controller="Clients" asp-action="Index" class="btn btn-primary">Client Overview</a>
    </div>
    <div class="dashboard-card">
        <h5>Contracts</h5>
        <p>Track contract timelines and statuses.</p>
        <a asp-controller="Contracts" asp-action="Index" class="btn btn-primary">Contract Overview</a>
    </div>
    <div class="dashboard-card">
        <h5>Service Requests</h5>
        <p>Monitor and process service requests.</p>
        <a asp-controller="ServiceRequests" asp-action="Index" class="btn btn-primary">Service Request Overview</a>
    </div>
    <div class="dashboard-card">
        <h5>Users</h5>
        <p>Manage system users and access roles.</p>
        <a asp-controller="Users" asp-action="Index" class="btn btn-primary">Users Overview</a>
    </div>
</div>
