@{
    ViewData["Title"] = "Privacy Policy";
}
<h1>@ViewData["Title"]</h1>

<div class="content-panel">
    <p>
        Global Logistics Management System is committed to protecting client and operational data.
        We only collect information required to manage contracts, service requests, and user access.
    </p>
    <p>
        Access to account and workflow data is role-based, and sensitive operations are handled through
        authenticated sessions and secure server-side validation.
    </p>
    <p class="mb-0">
        For data correction or access requests, please contact your system administrator.
    </p>
</div>
