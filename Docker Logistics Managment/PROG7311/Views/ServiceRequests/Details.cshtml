@using PROG7311.Services
@model PROG7311.Models.ServiceRequest

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>ServiceRequest</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            Client
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Client.Name)
        </dd>
        <dt class = "col-sm-2">
            Region
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Client.Region)
        </dd>
        <dt class = "col-sm-2">
            Service Level
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Contract.ServiceLevel)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Description)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Description)
        </dd>
        <dt class = "col-sm-2">
            Charge (regional)
        </dt>
        <dd class = "col-sm-10">
            @CurrencyDisplay.FormatMoney(Model.Cost, Model.CostCurrencyCode)
        </dd>
        <dt class = "col-sm-2">
            Amount (ZAR)
        </dt>
        <dd class = "col-sm-10">
            @CurrencyDisplay.FormatZar(Model.CostInZar)
            @if (Model.CurrencyRateDate.HasValue)
            {
                <div class="text-muted small">Rate date: @Model.CurrencyRateDate.Value.ToString("yyyy-MM-dd") (1 @Model.CostCurrencyCode ≈ R @Model.ExchangeRateToZar.ToString(System.Globalization.CultureInfo.InvariantCulture) ZAR)</div>
            }
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Status)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Status)
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model?.ServiceRequestId">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>
