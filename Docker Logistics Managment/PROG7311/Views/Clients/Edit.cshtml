@model PROG7311.Models.Client

@{
    ViewData["Title"] = "Edit";
    var fromClient = ViewBag.FromClient is bool isFromClient && isFromClient;
}

<h1>Edit</h1>

<h4>Client</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <input type="hidden" name="fromClient" value="@fromClient.ToString().ToLowerInvariant()" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="ClientId" />
            <div class="form-group">
                <label asp-for="Name" class="control-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ContactDetails" class="control-label"></label>
                <input asp-for="ContactDetails" class="form-control" />
                <span asp-validation-for="ContactDetails" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Region" class="control-label"></label>
                <select asp-for="Region" class="form-control">
                    <option value="">-- Select Region --</option>
                    <option value="USA">USA</option>
                    <option value="UK">United Kingdom</option>
                    <option value="European Union">European Union</option>
                    <option value="Japan">Japan</option>
                    <option value="China">China</option>
                    <option value="Australia">Australia</option>
                    <option value="Canada">Canada</option>
                    <option value="South Africa">South Africa</option>
                </select>
                <span asp-validation-for="Region" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    @if (fromClient)
    {
        <a asp-controller="ClientService" asp-action="Index">Back to Client Service</a>
    }
    else
    {
        <a asp-action="Index">Back to List</a>
    }
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
