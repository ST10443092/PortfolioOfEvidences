@model PROG7311.Models.Client

@{
    ViewData["Title"] = "Details";
    var fromClient = ViewBag.FromClient is bool isFromClient && isFromClient;
}

<h1>Details</h1>

<div>
    <h4>Client</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Name)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Name)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.ContactDetails)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.ContactDetails)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Region)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Region)
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model?.ClientId" asp-route-fromClient="@fromClient">Edit</a> |
    @if (fromClient)
    {
        <a asp-controller="ClientService" asp-action="Index">Back to Client Service</a>
    }
    else
    {
        <a asp-action="Index">Back to List</a>
    }
</div>
