@model IEnumerable<PROG7311.Models.Client>

@{
    ViewData["Title"] = "Index";
    var fromClient = ViewBag.FromClient is bool isFromClient && isFromClient;
}

<div class="page-header">
    <div>
        <h1 class="page-title">Clients</h1>
        <p class="page-subtitle">Client directory and account management.</p>
    </div>
</div>

<div class="action-bar mb-3">
    <a asp-action="Create" asp-route-fromClient="@fromClient" class="btn btn-primary">Create Client</a>
</div>

<div class="content-panel">
<table class="table mb-0">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ContactDetails)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Region)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ContactDetails)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Region)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.ClientId" asp-route-fromClient="@fromClient">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.ClientId" asp-route-fromClient="@fromClient">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.ClientId" asp-route-fromClient="@fromClient">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
</div>
