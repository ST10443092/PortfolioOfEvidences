@{
    ViewData["Title"] = "CR7 Login";
}

<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@700&family=Poppins:wght@400;600&display=swap" rel="stylesheet">

<style>
    body {
        background: linear-gradient(135deg, #000000, #1a1a1a);
        font-family: 'Poppins', sans-serif;
        color: #fff;
        height: 100vh;
        margin: 0;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .login-container {
        background: rgba(255,255,255,0.08);
        border-radius: 20px;
        padding: 45px 55px;
        box-shadow: 0 8px 40px rgba(0,0,0,0.7);
        width: 100%;
        max-width: 420px;
        text-align: center;
        backdrop-filter: blur(10px);
        animation: fadeIn 0.8s ease;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }

    .cr7-logo {
        font-family: 'Cinzel', serif;
        font-size: 3rem;
        font-weight: 700;
        background: linear-gradient(45deg, #d4af37, #ffd700, #DA291C);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        text-shadow: 0 2px 10px rgba(0,0,0,0.7);
        margin-bottom: 0.3rem;
    }

    .subtitle {
        color: #d4af37;
        font-weight: 500;
        margin-bottom: 30px;
        letter-spacing: 1px;
    }

    .form-control {
        background: rgba(255,255,255,0.1);
        border: 1px solid rgba(255,255,255,0.2);
        color: #fff;
        border-radius: 10px;
        padding: 12px;
        transition: all 0.3s ease;
    }

        .form-control:focus {
            border-color: #ffd700;
            background: rgba(255,255,255,0.15);
            box-shadow: 0 0 10px rgba(255,215,0,0.4);
        }

    .btn-login {
        background: linear-gradient(45deg, #DA291C, #00529F);
        color: #fff;
        border: none;
        border-radius: 50px;
        font-weight: 600;
        padding: 12px 0;
        width: 100%;
        margin-top: 15px;
        transition: all 0.3s ease;
    }

        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(218, 41, 28, 0.4);
            background: linear-gradient(45deg, #00529F, #DA291C);
        }

    .footer {
        margin-top: 25px;
        font-size: 0.85rem;
        color: #999;
    }

    a {
        color: #ffd700;
        text-decoration: none;
    }

        a:hover {
            text-decoration: underline;
        }
</style>

<div class="login-container">
    <h1 class="cr7-logo">CR7</h1>
    <p class="subtitle">Welcome to The 7th Era</p>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="validation-summary" style="background: rgba(255, 107, 107, 0.1); border: 1px solid rgba(255, 107, 107, 0.3); border-radius: 10px; padding: 15px; margin-bottom: 20px; color: #ff6b6b;">
            <div asp-validation-summary="All"></div>
        </div>
    }

    <form asp-controller="Home" asp-action="Login" method="post">
        @Html.AntiForgeryToken()
        <div class="mb-3">
            <input type="email" name="Email" class="form-control" placeholder="Email address" required />
        </div>

        <div class="mb-3">
            <input type="password" name="Password" class="form-control" placeholder="Password" required />
        </div>

        <button type="submit" class="btn-login">
            <i class="fas fa-sign-in-alt"></i> Sign In
        </button>
    </form>

    <div class="footer">
        <p>Don't have an account? <a asp-controller="Home" asp-action="Register">Sign Up</a></p>
        <p>© 2025 CR7 Official Store</p>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/js/all.min.js"></script>
}
