@model CLDV6212P1.Models.Product

@{
    ViewData["Title"] = "Delete Product";
}

<div class="container">
    <h1 class="text-danger mb-4">Delete Product</h1>
    
    <div class="alert alert-danger">
        <h4>Are you sure you want to delete this product?</h4>
        <p class="mb-0">This action cannot be undone.</p>
    </div>
    
    <div class="row">
        <div class="col-md-6">
            <div class="card mb-4">
                <div class="card-body">
                    <div class="text-center mb-3">
                        <img src="@Model.ImageUrl" class="img-fluid delete-product-image" onerror="this.src='/images/placeholder.jpg'" />
                    </div>
                    
                    <h4 class="card-title">@Model.Name</h4>
                    <div class="price mb-2">@Model.Price.ToString("C")</div>
                    <div class="mb-2"><strong>Stock:</strong> @Model.StockQuantity</div>
                    <p class="card-text">@Model.Description</p>
                </div>
            </div>
            
            <form asp-action="Delete">
                <input type="hidden" asp-for="PartitionKey" />
                <input type="hidden" asp-for="RowKey" />
                
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-danger flex-grow-1">
                        <i class="fas fa-trash-alt"></i> Confirm Delete
                    </button>
                    <a asp-action="Details" asp-route-partitionKey="@Model.PartitionKey" asp-route-rowKey="@Model.RowKey" class="btn btn-outline-secondary">
                        <i class="fas fa-arrow-left"></i> Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .delete-product-image {
        max-height: 200px;
        width: auto;
        object-fit: contain;
        background: #f8f9fa;
        padding: 10px;
        border-radius: 8px;
    }
    
    .price {
        font-size: 1.4rem;
        font-weight: bold;
        color: #b12704;
    }
</style>