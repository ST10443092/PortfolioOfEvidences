@model CLDV6212P1.Models.Product

@{
    ViewData["Title"] = "Create Product";
}

<h1>Create New Product</h1>

<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <!-- Product Name -->
            <div class="form-group mb-3">
                <label asp-for="Name" class="control-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <!-- Description -->
            <div class="form-group mb-3">
                <label asp-for="Description" class="control-label"></label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <!-- Price -->
            <div class="form-group mb-3">
                <label asp-for="Price" class="control-label"></label>
                <input asp-for="Price" class="form-control" type="number" step="0.01" min="0.01" />
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>

            <!-- Stock Quantity -->
            <div class="form-group mb-3">
                <label asp-for="StockQuantity" class="control-label">Stock Quantity</label>
                <input asp-for="StockQuantity" class="form-control" type="number" min="0" />
                <span asp-validation-for="StockQuantity" class="text-danger"></span>
            </div>

            <!-- Product Image Upload -->
            <div class="form-group mb-3">
                <label class="control-label">Product Image</label>
                <input type="file" name="imageFile" class="form-control" accept="image/*" required />
                <small class="form-text text-muted">Upload a product image (JPG, PNG, etc.)</small>
                <span class="text-danger">@Html.ValidationMessage("ImageFile")</span>
            </div>

            <!-- Supplier Contract Upload -->
            <div class="form-group mb-3">
                <label class="control-label">Supplier Contract (PDF only)</label>
                <input type="file" name="contractFile" class="form-control" accept=".pdf" required />
                <small class="form-text text-muted">Upload the supplier contract document (PDF format required)</small>
                <span class="text-danger">@Html.ValidationMessage("ContractFile")</span>
            </div>

            <!-- Submit Button -->
            <div class="form-group mt-4">
                <input type="submit" value="Create" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary ml-2">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}