@model CLDV6212P1.Models.CheckoutViewModel

@{
    ViewData["Title"] = "Checkout";
}

<style>
    body {
        background: linear-gradient(135deg, #000000, #1a1a1a);
        font-family: 'Poppins', sans-serif;
        color: #fff;
        min-height: 100vh;
    }

    .checkout-container {
        max-width: 700px;
        margin: 3rem auto;
        background: rgba(0, 0, 0, 0.85);
        padding: 2rem;
        border-radius: 20px;
        box-shadow: 0 0 30px rgba(212, 175, 55, 0.2);
    }

    h2 {
        font-family: 'Cinzel', serif;
        background: linear-gradient(45deg, #d4af37, #ffd700, #006600);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        text-align: center;
        margin-bottom: 2rem;
        text-shadow: 2px 2px 8px rgba(0, 0, 0, 0.6);
    }

    label {
        font-weight: 600;
        color: #ffd700;
    }

    .form-control {
        background: #222;
        border: 1px solid #444;
        color: #fff;
    }

        .form-control:focus {
            border-color: #d4af37;
            box-shadow: 0 0 10px rgba(212, 175, 55, 0.5);
        }

    .btn-checkout {
        background: linear-gradient(45deg, #DA291C, #00529F);
        border: none;
        border-radius: 50px;
        font-weight: bold;
        color: #fff;
        padding: 10px 30px;
        width: 100%;
        transition: transform 0.2s ease, box-shadow 0.3s ease;
    }

        .btn-checkout:hover {
            transform: scale(1.03);
            box-shadow: 0 0 20px rgba(218, 41, 28, 0.6);
            background: linear-gradient(45deg, #00529F, #DA291C);
        }

    .back-link {
        display: inline-block;
        margin-top: 1rem;
        color: #d4af37;
        text-decoration: none;
        transition: color 0.2s ease;
    }

        .back-link:hover {
            color: #fff;
        }

    .text-danger {
        font-size: 0.9rem;
    }
</style>

<div class="checkout-container">
    <h2>Secure Checkout</h2>

    <form asp-action="Checkout" method="post" novalidate>
        <div class="mb-3">
            <label asp-for="CustomerEmail" class="form-label">Email Address</label>
            <input asp-for="CustomerEmail" class="form-control" placeholder="example@email.com" />
            <span asp-validation-for="CustomerEmail" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="DeliveryAddress" class="form-label">Delivery Address</label>
            <textarea asp-for="DeliveryAddress" class="form-control" rows="3" placeholder="Enter your delivery address"></textarea>
            <span asp-validation-for="DeliveryAddress" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-checkout mt-3">
            <i class="fas fa-lock"></i> Confirm & Place Order
        </button>

        <a asp-controller="Cart" asp-action="Index" class="back-link">
            <i class="fas fa-arrow-left"></i> Back to Cart
        </a>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" />
}
