@model List<CLDV6212P1.Models.CartItem>

@{
    ViewData["Title"] = "Your Cart";
    double grandTotal = Model.Sum(item => item.TotalPrice);
}

<style>
    body {
        background: linear-gradient(135deg, #000000, #1a1a1a);
        font-family: 'Poppins', sans-serif;
        color: #ffffff;
        min-height: 100vh;
    }

    h2 {
        font-family: 'Cinzel', serif;
        font-weight: 700;
        background: linear-gradient(45deg, #d4af37, #ffd700, #006600);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        text-align: center;
        margin-top: 40px;
        text-shadow: 2px 2px 10px rgba(0, 0, 0, 0.7);
    }

    table {
        background-color: #111;
        border-radius: 12px;
        overflow: hidden;
    }

    th {
        color: #d4af37;
        text-transform: uppercase;
        letter-spacing: 1px;
        border-bottom: 2px solid #d4af37;
    }

    td {
        vertical-align: middle;
    }

    .product-img {
        width: 60px;
        height: 60px;
        border-radius: 8px;
        object-fit: cover;
    }

    .btn-danger {
        background-color: #DA291C;
        border: none;
    }

        .btn-danger:hover {
            background-color: #a61b12;
        }

    .btn-clear {
        background-color: transparent;
        border: 1px solid #FFD700;
        color: #FFD700;
        border-radius: 20px;
        transition: 0.3s ease;
    }

        .btn-clear:hover {
            background-color: #FFD700;
            color: #000;
        }

    .btn-checkout {
        background: linear-gradient(45deg, #DA291C, #00529F);
        border: none;
        border-radius: 50px;
        font-weight: 600;
        color: #fff;
        padding: 10px 30px;
        transition: 0.3s ease;
    }

        .btn-checkout:hover {
            transform: scale(1.03);
            box-shadow: 0 0 20px rgba(218, 41, 28, 0.6);
            background: linear-gradient(45deg, #00529F, #DA291C);
        }

    .summary-box {
        background: #000;
        border-radius: 12px;
        padding: 20px;
        text-align: right;
        box-shadow: 0 0 20px rgba(212, 175, 55, 0.15);
    }

        .summary-box h4 {
            color: #FFD700;
        }

    .empty {
        text-align: center;
        margin-top: 100px;
        color: #aaa;
    }
</style>

<h2>Your Shopping Cart</h2>

@if (!Model.Any())
{
    <div class="empty">
        <i class="fas fa-shopping-cart fa-3x mb-3"></i>
        <h4>Your cart is empty.</h4>
        <a asp-controller="Home" asp-action="Index" class="btn btn-checkout mt-3">
            <i class="fas fa-store"></i> Continue Shopping
        </a>
    </div>
}
else
{
    <div class="container mt-5">
        <table class="table table-dark table-hover align-middle">
            <thead>
                <tr>
                    <th>Product</th>
                    <th>Size</th>
                    <th>Price</th>
                    <th>Quantity</th>
                    <th>Total</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div class="d-flex align-items-center">
                                <img src="@item.ImageUrl" class="product-img me-2" onerror="this.src='https://via.placeholder.com/60x60?text=CR7'" />
                                <span>@item.ProductName</span>
                            </div>
                        </td>
                        <td>@item.Size</td>
                        <td>@item.UnitPrice.ToString("C")</td>
                        <td>
                            <form asp-action="UpdateQuantity" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="productId" value="@item.ProductId" />
                                <input type="hidden" name="size" value="@item.Size" />
                                <input type="number" name="quantity" value="@item.Quantity" min="1" max="99" 
                                       class="form-control form-control-sm d-inline-block" style="width: 70px;" 
                                       onchange="this.form.submit()" />
                            </form>
                        </td>
                        <td>@item.TotalPrice.ToString("C")</td>
                        <td>
                            <a asp-action="Remove"
                               asp-route-productId="@item.ProductId"
                               asp-route-size="@item.Size"
                               class="btn btn-sm btn-danger">
                                <i class="fas fa-trash-alt"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="d-flex justify-content-between align-items-center mt-4">
            <a asp-action="Clear" class="btn btn-clear">
                <i class="fas fa-times-circle"></i> Clear Cart
            </a>

            <div class="summary-box">
                <h4>Total: @grandTotal.ToString("C")</h4>
                <a asp-action="Checkout" class="btn btn-checkout mt-2">
                    <i class="fas fa-lock"></i> Proceed to Checkout
                </a>
            </div>
        </div>
    </div>
}

@section Scripts {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" />
}
