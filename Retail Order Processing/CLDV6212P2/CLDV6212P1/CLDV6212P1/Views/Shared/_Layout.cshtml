<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CR7 Shop</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CLDV6212P1.styles.css" asp-append-version="true" />

    <style>
        body {
            background-color: #121212;
            color: #f5f5f5;
        }

        .navbar {
            background-color: #000 !important;
        }

            .navbar .nav-link, .navbar-brand {
                color: #FFD700 !important;
                font-weight: 600;
            }

                .navbar .nav-link:hover {
                    color: #fff !important;
                }

        .btn-primary {
            background-color: #FFD700;
            border-color: #FFD700;
            color: #000;
            font-weight: bold;
        }

            .btn-primary:hover {
                background-color: #e6c200;
                border-color: #e6c200;
            }

        footer {
            background-color: #000;
            color: #FFD700;
            padding: 10px 0;
        }

        a {
            color: #FFD700;
        }

            a:hover {
                color: #fff;
            }
    </style>
</head>

@{
        var role = (Context.Session.GetString("UserRole") ?? "").Trim().ToLower();
        var userName = Context.Session.GetString("UserName");
}

<body>

    @if (!string.IsNullOrEmpty(role))
    {
        <header>
            <nav class="navbar navbar-expand-sm navbar-toggleable-sm border-bottom box-shadow mb-3">
                <div class="container-fluid">

                    <a class="navbar-brand" asp-controller="Home" asp-action="Index">The Seventh Era</a>

                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                            aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon" style="filter: invert(1);"></span>
                    </button>

                    <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                        @* ---- CUSTOMER OR USER ---- *@
                        @if (role == "customer" || role == "user")
                        {
                            <ul class="navbar-nav flex-grow-1">
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                                </li>
                            </ul>

                            <ul class="navbar-nav ms-auto">
                                <li class="nav-item"><span class="nav-link">Welcome, @userName</span></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Logout"><i class="fas fa-sign-out-alt"></i> Logout</a></li>
                            </ul>
                        }
                        @* ---- ADMIN OR MANAGER ---- *@
                        else if (role == "admin" || role == "manager")
                        {
                            <ul class="navbar-nav flex-grow-1">
                                <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Home</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Privacy">Privacy</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Orders" asp-action="Index"><i class="fas fa-list"></i> View Orders</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Orders" asp-action="Customer"><i class="fas fa-users"></i> Customers</a></li>
                            </ul>

                            <ul class="navbar-nav ms-auto">
                                <li class="nav-item"><span class="nav-link">Welcome, @userName</span></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Logout"><i class="fas fa-sign-out-alt"></i> Logout</a></li>
                            </ul>
                        }
                        @* ---- UNKNOWN ROLE (fallback) ---- *@
                        else
                        {
                            <ul class="navbar-nav flex-grow-1">
                                <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Home</a></li>
                            </ul>

                            <ul class="navbar-nav ms-auto">
                                <li class="nav-item"><span class="nav-link">Welcome, @userName</span></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Logout"><i class="fas fa-sign-out-alt"></i> Logout</a></li>
                            </ul>
                        }

                    </div>
                </div>
            </nav>
        </header>
    }

    <div class="container">
        <main role="main" class="pb-3">@RenderBody()</main>
    </div>

    <footer class="border-top footer text-center">
        <div class="container">&copy; 2025 - CR7 Shop - <a asp-controller="Home" asp-action="Privacy">Privacy</a></div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
