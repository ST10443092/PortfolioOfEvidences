<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    tools:context=".AddExpense">
    <!-- Title -->
    <!--(Android Developers, n.d.)-->
    <TextView
        android:id="@+id/tvAddExpenseTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add Expense"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#2B2B2B"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Amount -->
    <TextView
        android:id="@+id/tvAmountLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Amount (R)"
        android:layout_marginTop="18dp"
        app:layout_constraintTop_toBottomOf="@id/tvAddExpenseTitle"
        app:layout_constraintStart_toStartOf="parent" />
    <EditText
        android:id="@+id/etAmount"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="e.g. 120.50"
        android:inputType="numberDecimal"
        android:padding="14dp"
        app:layout_constraintTop_toBottomOf="@id/tvAmountLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Category -->
    <TextView
        android:id="@+id/tvCategoryLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Category"
        android:layout_marginTop="14dp"
        app:layout_constraintTop_toBottomOf="@id/etAmount"
        app:layout_constraintStart_toStartOf="parent" />

    <Spinner
        android:id="@+id/spCategory"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:padding="10dp"
        app:layout_constraintTop_toBottomOf="@id/tvCategoryLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Date -->
    <TextView
        android:id="@+id/tvDateLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Date"
        android:layout_marginTop="14dp"
        app:layout_constraintTop_toBottomOf="@id/spCategory"
        app:layout_constraintStart_toStartOf="parent" />

    <EditText
        android:id="@+id/etDate"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="YYYY-MM-DD"
        android:padding="14dp"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:cursorVisible="false"
        app:layout_constraintTop_toBottomOf="@id/tvDateLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Start Time -->
    <TextView
        android:id="@+id/tvStartTimeLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Start Time"
        android:layout_marginTop="14dp"
        app:layout_constraintTop_toBottomOf="@id/etDate"
        app:layout_constraintStart_toStartOf="parent" />

    <EditText
        android:id="@+id/etStartTime"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="HH:MM"
        android:padding="14dp"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:cursorVisible="false"
        app:layout_constraintTop_toBottomOf="@id/tvStartTimeLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- End Time -->
    <TextView
        android:id="@+id/tvEndTimeLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="End Time"
        android:layout_marginTop="14dp"
        app:layout_constraintTop_toBottomOf="@id/etStartTime"
        app:layout_constraintStart_toStartOf="parent" />

    <EditText
        android:id="@+id/etEndTime"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="HH:MM"
        android:padding="14dp"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:cursorVisible="false"
        app:layout_constraintTop_toBottomOf="@id/tvEndTimeLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />
    <!--(Android Developers, n.d.)-->
    <!-- Notes -->
    <TextView
        android:id="@+id/tvNotesLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Notes (optional)"
        android:layout_marginTop="14dp"
        app:layout_constraintTop_toBottomOf="@id/etEndTime"
        app:layout_constraintStart_toStartOf="parent" />

    <EditText
        android:id="@+id/etNotes"
        android:layout_width="0dp"
        android:layout_height="120dp"
        android:hint="e.g. Lunch with friends"
        android:gravity="top"
        android:inputType="textMultiLine"
        android:padding="14dp"
        app:layout_constraintTop_toBottomOf="@id/tvNotesLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!--(Android Developers, n.d.)-->
    <!-- Receipt Button -->
    <Button
        android:id="@+id/btnAddReceipt"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Add Receipt Photo (Optional)"
        android:layout_marginTop="14dp"
        app:layout_constraintTop_toBottomOf="@id/etNotes"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!--(Android Developers, n.d.)-->
    <!-- Save Button -->
    <Button
        android:id="@+id/btnSaveExpense"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Save Expense"
        android:layout_marginTop="14dp"
        app:layout_constraintTop_toBottomOf="@id/btnAddReceipt"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Cancel -->
    <!--(Android Developers, n.d.)-->
    <TextView
        android:id="@+id/tvCancel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Cancel"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/btnSaveExpense"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
