<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".AddCategory">

    <!--(Android Developers, n.d.)-->
    <TextView
        android:id="@+id/tvAddCategoryTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add Category"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#2B2B2B"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvAddCategorySubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Create a new expense category"
        android:textSize="16sp"
        android:textColor="#6B6B6B"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvAddCategoryTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!--(Android Developers, n.d.)-->

    <EditText
        android:id="@+id/etCategoryName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Category Name"
        android:inputType="textCapWords"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/tvAddCategorySubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />
    <EditText
        android:id="@+id/etCategoryDescription"
        android:layout_width="0dp"
        android:layout_height="120dp"
        android:hint="Description (optional)"
        android:gravity="top"
        android:inputType="textMultiLine"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/etCategoryName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvCategoryTypeLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Category Type"
        android:textSize="14sp"
        android:textColor="#6B6B6B"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/etCategoryDescription"
        app:layout_constraintStart_toStartOf="parent" />
    <!--(Android Developers, n.d.)-->

    <Spinner
        android:id="@+id/spCategoryType"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvCategoryTypeLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />
    <!--(Android Developers, n.d.)-->
    <Button
        android:id="@+id/btnSaveCategory"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Save Category"
        android:textColor="#FFFFFF"
        android:backgroundTint="#5A43A5"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/spCategoryType"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />
<!--(Android Developers, n.d.)-->
    <TextView
        android:id="@+id/tvCancelCategory"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Cancel"
        android:textColor="#5A43A5"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/btnSaveCategory"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
