@model CLDV1.Models.Booking
@{
    ViewData["Title"] = "Booking Details";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"]</title>

    <!-- Bootstrap 5 & Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" crossorigin="anonymous" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />

    <style>
        body {
            background-color: #f9fafb;
            padding: 2rem;
        }

        .details-card {
            background: white;
            border-radius: 12px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            border: none;
            overflow: hidden;
        }

        .card-header {
            background-color: #3b82f6;
            color: white;
            border: none;
            padding: 1.5rem;
        }

            .card-header h4 {
                margin: 0;
                font-weight: 600;
            }

        .card-body {
            padding: 2rem;
        }

        .detail-label {
            font-weight: 600;
            color: #374151;
            margin-bottom: 0.5rem;
        }

        .detail-value {
            color: #6b7280;
            margin-bottom: 1.5rem;
            font-size: 1.1rem;
        }

        .venue-image-container {
            background: #f8fafc;
            border: 2px solid #e5e7eb;
            border-radius: 12px;
            padding: 1rem;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

            .venue-image-container:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 16px rgba(59, 130, 246, 0.15);
            }

        .venue-thumb-large {
            border-radius: 8px;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.15);
            transition: transform 0.3s ease;
        }

            .venue-thumb-large:hover {
                transform: scale(1.02);
            }

        .no-image-placeholder {
            background: linear-gradient(135deg, #f1f5f9 0%, #e2e8f0 100%);
            border: 2px dashed #cbd5e1;
            border-radius: 12px;
            height: 200px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            color: #64748b;
        }

        .card-footer {
            background-color: #f8fafc;
            border-top: 1px solid #e5e7eb;
            padding: 1.5rem;
        }

        .btn-primary {
            background-color: #3b82f6;
            border-color: #3b82f6;
            border-radius: 0.5rem;
            padding: 0.75rem 1.5rem;
            font-weight: 500;
            transition: all 0.3s ease;
        }

            .btn-primary:hover {
                background-color: #2563eb;
                border-color: #2563eb;
                transform: translateY(-1px);
                box-shadow: 0 4px 8px rgba(59, 130, 246, 0.3);
            }

        .btn-secondary {
            background-color: #6c757d;
            border-color: #6c757d;
            border-radius: 0.5rem;
            padding: 0.75rem 1.5rem;
            font-weight: 500;
            transition: all 0.3s ease;
        }

            .btn-secondary:hover {
                background-color: #5a6268;
                border-color: #5a6268;
                transform: translateY(-1px);
                box-shadow: 0 4px 8px rgba(108, 117, 125, 0.3);
            }

        .image-caption {
            margin-top: 0.75rem;
            font-size: 0.9rem;
            color: #6b7280;
            font-style: italic;
        }

        .detail-icon {
            color: #3b82f6;
            margin-right: 0.5rem;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="card details-card">
            <div class="card-header">
                <h4><i class="bi bi-info-circle-fill me-2"></i>Booking Details</h4>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-8">
                        <div class="details-section">
                            <div class="detail-item">
                                <div class="detail-label">
                                    <i class="bi bi-calendar-event detail-icon"></i>Booking Date:
                                </div>
                                <div class="detail-value">@Model.BookingDate.ToString("f")</div>
                            </div>

                            <div class="detail-item">
                                <div class="detail-label">
                                    <i class="bi bi-star-fill detail-icon"></i>Event:
                                </div>
                                <div class="detail-value">@Model.Event.EventName</div>
                            </div>

                            <div class="detail-item">
                                <div class="detail-label">
                                    <i class="bi bi-geo-alt-fill detail-icon"></i>Venue:
                                </div>
                                <div class="detail-value">@Model.Venue.Name</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        @if (!string.IsNullOrEmpty(Model.Venue.ImageUrl))
                        {
                            <div class="venue-image-container text-center">
                                <img src="@Model.Venue.ImageUrl"
                                     alt="@Model.Venue.Name"
                                     class="img-fluid venue-thumb-large"
                                     style="max-height: 200px; max-width: 100%;">
                                <div class="image-caption">@Model.Venue.Name</div>
                            </div>
                        }
                        else
                        {
                            <div class="no-image-placeholder">
                                <i class="bi bi-image" style="font-size: 3rem; color: #94a3b8;"></i>
                                <div class="mt-2 fw-medium">No image available</div>
                            </div>
                        }
                    </div>
                </div>
            </div>
            <div class="card-footer d-flex gap-3">
                <a asp-action="Edit" asp-route-id="@Model.BookingId" class="btn btn-primary">
                    <i class="bi bi-pencil-fill me-1"></i>Edit Booking
                </a>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left me-1"></i>Back to List
                </a>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
</body>
</html>