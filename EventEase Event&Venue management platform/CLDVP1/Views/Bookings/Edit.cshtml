@model CLDV1.Models.Booking

@{
    ViewData["Title"] = "Edit Booking";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Edit Booking</title>

    <!-- Bootstrap 5 & Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" crossorigin="anonymous" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />

    <style>
        body {
            background-color: #f4f6fc;
            padding: 2rem;
        }

        .form-container {
            max-width: 600px;
            margin: auto;
            background: #ffffff;
            padding: 2rem;
            border-radius: 15px;
            box-shadow: 0 0 15px rgba(0,0,0,0.1);
        }

        .form-title {
            color: #3b82f6;
        }

        .btn-save {
            background-color: #3b82f6;
            color: white;
            transition: background-color 0.3s ease;
        }

            .btn-save:hover {
                background-color: #2563eb;
            }

        .btn-back {
            margin-top: 1rem;
        }

        label {
            font-weight: 600;
        }

        .form-control:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 0.25rem rgba(59, 130, 246, 0.25);
        }

        .form-group {
            margin-bottom: 1rem;
        }
    </style>
</head>
<body>

    <div class="form-container">
        <h2 class="form-title mb-4"><i class="bi bi-pencil-square me-2"></i>Edit Booking</h2>

        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <input type="hidden" asp-for="BookingId" />

            <div class="form-group">
                <label asp-for="BookingDate" class="form-label">Booking Date</label>
                <input asp-for="BookingDate" class="form-control" />
                <span asp-validation-for="BookingDate" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="EventId" class="form-label">Event</label>
                <select asp-for="EventId" class="form-control" asp-items="ViewBag.EventId">
                    <option value="">-- Select Event --</option>
                </select>
                <span asp-validation-for="EventId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="EventTypeId" class="form-label">Event Type</label>
                <select asp-for="EventTypeId" class="form-control" asp-items="ViewBag.EventTypes">
                    <option value="">-- Select event type --</option>
                </select>
                <span asp-validation-for="EventTypeId" class="text-danger small"></span>
            </div>

            <div class="form-group">
                <label asp-for="VenueId" class="form-label">Venue</label>
                <select asp-for="VenueId" class="form-control" asp-items="ViewBag.VenueId">
                    <option value="">-- Select Venue --</option>
                </select>
                <span asp-validation-for="VenueId" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-save w-100">
                <i class="bi bi-check-circle me-1"></i>Save Changes
            </button>
        </form>

        <div class="text-center btn-back">
            <a asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left-circle me-1"></i>Back to List
            </a>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>

    @section Scripts {
        @{
            await Html.RenderPartialAsync("_ValidationScriptsPartial");
        }
    }
</body>
</html>
