@model CLDV1.Models.Booking

@{
    ViewData["Title"] = "Create Booking";
}

<!-- Bootstrap 5 & Icons CDN -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" crossorigin="anonymous" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />

<style>
    body {
        background-color: #f5f7fa;
        font-family: 'Segoe UI', sans-serif;
    }

    .booking-card {
        background-color: #ffffff;
        border-radius: 1rem;
        padding: 2.5rem 2rem;
        box-shadow: 0 12px 30px rgba(0, 0, 0, 0.1);
        transition: transform 0.4s ease, box-shadow 0.4s ease;
        animation: fadeInUp 0.6s ease-in-out both;
    }

    fadeInUp {
        from

    {
        opacity: 0;
        transform: translateY(40px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }

    .booking-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 18px 45px rgba(0, 0, 0, 0.12);
    }

    .form-label {
        color: #3f37c9;
        font-weight: 500;
    }

    .form-control {
        border-radius: 0.5rem;
        transition: border-color 0.3s ease, box-shadow 0.3s ease;
    }

        .form-control:focus {
            border-color: #4895ef;
            box-shadow: 0 0 0 0.25rem rgba(72, 149, 239, 0.25);
        }

    .btn-gradient {
        background-image: linear-gradient(to right, #4361ee, #3f37c9);
        border: none;
        color: white;
        font-weight: 500;
        border-radius: 0.5rem;
        transition: background 0.3s ease, transform 0.2s ease;
    }

        .btn-gradient:hover {
            background-image: linear-gradient(to right, #3f37c9, #4361ee);
            transform: scale(1.04);
        }

    .btn-outline-primary {
        border-color: #4895ef;
        color: #4895ef;
        font-weight: 500;
        border-radius: 0.5rem;
    }

        .btn-outline-primary:hover {
            background-color: #4895ef;
            color: white;
        }

    .back-link {
        color: #4895ef;
        text-decoration: none;
        font-weight: 500;
        transition: text-decoration 0.3s;
    }

        .back-link:hover {
            text-decoration: underline;
        }

    h2 {
        color: #3f37c9;
        font-weight: bold;
    }

    .text-muted {
        font-size: 0.95rem;
    }
</style>

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="booking-card">
                <h2 class="text-center mb-3">Create a Booking</h2>
                <p class="text-center text-muted mb-4">Fill in the details below to schedule a new booking</p>

                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="BookingDate" class="form-label">Booking Date</label>
                        <input asp-for="BookingDate" type="date" class="form-control" />
                        <span asp-validation-for="BookingDate" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="EventId" class="form-label">Select Event</label>
                        <select asp-for="EventId" class="form-control" asp-items="ViewBag.EventId">
                            <option value="">-- Select Event --</option>
                        </select>
                        <span asp-validation-for="EventId" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="VenueId" class="form-label">Select Venue</label>
                        <select asp-for="VenueId" class="form-control" asp-items="ViewBag.VenueId">
                            <option value="">-- Select Venue --</option>
                        </select>
                        <span asp-validation-for="VenueId" class="text-danger small"></span>
                    </div>
                      <div class="mb-3">
                        <label asp-for="EventTypeId" class="form-label">Event Type</label>
                        <select asp-for="EventTypeId" class="form-control" asp-items="ViewBag.EventTypes">
                            <option value="">-- Select event type --</option>
                        </select>
                        <span asp-validation-for="EventTypeId" class="text-danger small"></span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mt-4">
                        <a asp-action="Index" class="back-link">← Back to List</a>
                        <button type="submit" class="btn btn-gradient px-4">
                            <i class="bi bi-check-circle-fill me-1"></i> Create Booking
                        </button>
                    </div>
                </form>

                <div class="text-center mt-4">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary">
                        <i class="bi bi-house-door-fill me-1"></i> Home
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Bootstrap JS Bundle -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
