@model IEnumerable<CLDV1.Models.Booking>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Bookings</title>

    <!-- Bootstrap 5 & Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" crossorigin="anonymous" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />

    <style>
        body {
            background-color: #f9fafb;
            padding: 2rem;
        }

        .table th {
            background-color: #3b82f6;
            color: white;
        }

        .table-hover tbody tr:hover {
            background-color: #e6f0ff;
            transition: background-color 0.3s ease-in-out;
        }

        .venue-thumb {
            width: 80px;
            height: 80px;
            object-fit: cover;
            border-radius: 8px;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
            transition: transform 0.3s ease;
        }

            .venue-thumb:hover {
                transform: scale(1.05);
            }

        .btn-create {
            background-color: #3b82f6;
            color: white;
            border-radius: 0.5rem;
            transition: background-color 0.3s ease;
        }

            .btn-create:hover {
                background-color: #2563eb;
                color: white;
            }

        .action-btn {
            margin-right: 0.5rem;
            transition: transform 0.2s ease;
        }

            .action-btn:hover {
                transform: scale(1.1);
            }

        .btn-done {
            margin-top: 1rem;
            background-color: #6c757d;
            border: none;
        }

            .btn-done:hover {
                background-color: #5a6268;
            }
    </style>
</head>
<body>
    <div class="container bg-white rounded shadow p-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="text-primary"><i class="bi bi-calendar-check-fill me-2"></i>Bookings</h2>
            <a href="/Bookings/Create" class="btn btn-create">
                <i class="bi bi-plus-circle-fill me-1"></i>Create New Booking
            </a>
        </div>

        <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle">
                <thead>
                    <tr>
                        <th scope="col">Date</th>
                        <th scope="col">Event</th>
                        <th scope="col">Venue</th>
                        <th scope="col">Image</th>
                        <th scope="col">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.BookingDate.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@(item.Event?.EventId)</td>
                            <td>@(item.Venue?.Name)</td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.Venue?.ImageUrl))
                                {
                                    <img src="@item.Venue.ImageUrl" class="venue-thumb" alt="Venue Image" />
                                }
                                else
                                {
                                    <span class="text-muted">No Image</span>
                                }
                            </td>
                            <td>
                                <a href="/Bookings/Edit/@item.BookingId" class="btn btn-sm btn-outline-primary action-btn">
                                    <i class="bi bi-pencil-fill"></i>
                                </a>
                                <a href="/Bookings/Details/@item.BookingId" class="btn btn-sm btn-outline-info action-btn">
                                    <i class="bi bi-info-circle-fill"></i>
                                </a>
                                <a href="/Bookings/Delete/@item.BookingId" class="btn btn-sm btn-outline-danger action-btn">
                                    <i class="bi bi-trash-fill"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="text-center">
            <a href="/Home/Index" class="btn btn-done text-white">
                <i class="bi bi-house-door-fill me-1"></i>Back to Home
            </a>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
</body>
</html>
