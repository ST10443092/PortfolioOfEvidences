@{
    ViewData["Title"] = "Event Management Portal";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
            color: #1f2937;
            overflow-x: hidden;
        }

        .hero-section {
            background: linear-gradient(135deg, #3b82f6 0%, #2563eb 50%, #1d4ed8 100%);
            color: white;
            padding: 5rem 0;
            position: relative;
            overflow: hidden;
        }

            .hero-section::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><defs><pattern id="grid" width="10" height="10" patternUnits="userSpaceOnUse"><path d="M 10 0 L 0 0 0 10" fill="none" stroke="rgba(255,255,255,0.1)" stroke-width="1"/></pattern></defs><rect width="100" height="100" fill="url(%23grid)"/></svg>');
                opacity: 0.3;
            }

        .hero-content {
            position: relative;
            z-index: 2;
        }

        .hero-title {
            font-size: 3.5rem;
            font-weight: 700;
            margin-bottom: 1.5rem;
            text-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
            animation: slideInFromTop 1s ease-out;
        }

        .hero-subtitle {
            font-size: 1.3rem;
            margin-bottom: 2rem;
            opacity: 0.95;
            animation: slideInFromBottom 1s ease-out 0.3s both;
        }

        .hero-stats {
            display: flex;
            justify-content: center;
            gap: 3rem;
            margin-top: 3rem;
            animation: fadeIn 1s ease-out 0.6s both;
        }

        .stat-item {
            text-align: center;
        }

        .stat-number {
            display: block;
            font-size: 2.5rem;
            font-weight: 700;
            color: #fbbf24;
        }

        .stat-label {
            font-size: 0.9rem;
            opacity: 0.8;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .workflow-section {
            padding: 5rem 0;
            background: white;
            position: relative;
        }

        .section-header {
            text-align: center;
            margin-bottom: 5rem;
        }

        .section-title {
            font-size: 2.5rem;
            font-weight: 700;
            color: #1f2937;
            margin-bottom: 1rem;
        }

        .section-subtitle {
            font-size: 1.1rem;
            color: #6b7280;
            max-width: 600px;
            margin: 0 auto;
        }

        .workflow-container {
            position: relative;
            max-width: 1200px;
            margin: 0 auto;
        }

        .workflow-line {
            position: absolute;
            top: 80px;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, #3b82f6, #10b981, #f59e0b);
            border-radius: 2px;
            z-index: 1;
        }

        .step-card {
            background: white;
            border-radius: 16px;
            padding: 2.5rem;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.08);
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            height: 100%;
            position: relative;
            z-index: 2;
            border: 1px solid #f3f4f6;
            overflow: hidden;
        }

            .step-card::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 4px;
                background: linear-gradient(90deg, #3b82f6, #2563eb);
                transform: scaleX(0);
                transition: transform 0.3s ease;
            }

            .step-card:hover {
                transform: translateY(-8px);
                box-shadow: 0 20px 40px rgba(59, 130, 246, 0.15);
            }

                .step-card:hover::before {
                    transform: scaleX(1);
                }

        .step-number {
            width: 60px;
            height: 60px;
            background: linear-gradient(135deg, #3b82f6, #2563eb);
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 2rem;
            font-weight: 700;
            font-size: 1.5rem;
            box-shadow: 0 8px 16px rgba(59, 130, 246, 0.3);
            position: relative;
            z-index: 3;
        }

        .step-card:nth-child(2) .step-number {
            background: linear-gradient(135deg, #10b981, #059669);
            box-shadow: 0 8px 16px rgba(16, 185, 129, 0.3);
        }

        .step-card:nth-child(3) .step-number {
            background: linear-gradient(135deg, #f59e0b, #d97706);
            box-shadow: 0 8px 16px rgba(245, 158, 11, 0.3);
        }

        .step-title {
            font-size: 1.5rem;
            font-weight: 600;
            margin-bottom: 1rem;
            color: #1f2937;
        }

        .step-description {
            color: #6b7280;
            margin-bottom: 2rem;
            line-height: 1.6;
        }

        .step-action {
            background: linear-gradient(135deg, #3b82f6, #2563eb);
            border: none;
            color: white;
            padding: 0.75rem 2rem;
            border-radius: 10px;
            font-weight: 600;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
        }

            .step-action:hover {
                background: linear-gradient(135deg, #2563eb, #1d4ed8);
                transform: translateY(-2px);
                box-shadow: 0 8px 16px rgba(59, 130, 246, 0.4);
                color: white;
            }

        .step-card:nth-child(2) .step-action {
            background: linear-gradient(135deg, #10b981, #059669);
        }

            .step-card:nth-child(2) .step-action:hover {
                background: linear-gradient(135deg, #059669, #047857);
                box-shadow: 0 8px 16px rgba(16, 185, 129, 0.4);
            }

        .step-card:nth-child(3) .step-action {
            background: linear-gradient(135deg, #f59e0b, #d97706);
        }

            .step-card:nth-child(3) .step-action:hover {
                background: linear-gradient(135deg, #d97706, #b45309);
                box-shadow: 0 8px 16px rgba(245, 158, 11, 0.4);
            }

        .quick-access-section {
            padding: 4rem 0;
            background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
        }

        .quick-access-panel {
            background: white;
            border-radius: 20px;
            padding: 3rem;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);
            max-width: 800px;
            margin: 0 auto;
        }

        .quick-access-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 1.5rem;
            margin-top: 2rem;
        }

        .quick-access-btn {
            background: white;
            border: 2px solid #e5e7eb;
            color: #374151;
            padding: 1.5rem;
            border-radius: 12px;
            text-decoration: none;
            transition: all 0.3s ease;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.5rem;
            font-weight: 500;
        }

            .quick-access-btn:hover {
                border-color: #3b82f6;
                color: #3b82f6;
                transform: translateY(-4px);
                box-shadow: 0 12px 24px rgba(59, 130, 246, 0.15);
            }

        .quick-access-icon {
            font-size: 2rem;
            margin-bottom: 0.5rem;
        }

        .floating-elements {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: -1;
        }

        .floating-circle {
            position: absolute;
            border-radius: 50%;
            background: linear-gradient(135deg, rgba(59, 130, 246, 0.1), rgba(37, 99, 235, 0.05));
            animation: float 6s ease-in-out infinite;
        }

            .floating-circle:nth-child(1) {
                width: 100px;
                height: 100px;
                top: 20%;
                left: 10%;
                animation-delay: 0s;
            }

            .floating-circle:nth-child(2) {
                width: 150px;
                height: 150px;
                top: 60%;
                right: 10%;
                animation-delay: 2s;
            }

            .floating-circle:nth-child(3) {
                width: 80px;
                height: 80px;
                bottom: 20%;
                left: 20%;
                animation-delay: 4s;
            }

        keyframes slideInFromTop {
            from

        {
            opacity: 0;
            transform: translateY(-50px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }

        }

        keyframes slideInFromBottom {
            from

        {
            opacity: 0;
            transform: translateY(50px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }

        }

        keyframes fadeIn {
            from

        {
            opacity: 0;
        }

        to {
            opacity: 1;
        }

        }

        keyframes float {
            0%, 100%

        {
            transform: translateY(0px);
        }

        50% {
            transform: translateY(-20px);
        }

        }

        .scroll-indicator {
            position: absolute;
            bottom: 2rem;
            left: 50%;
            transform: translateX(-50%);
            color: white;
            animation: bounce 2s infinite;
        }

        keyframes bounce {
            0%, 20%, 50%, 80%, 100%

        {
            transform: translateX(-50%) translateY(0);
        }

        40% {
            transform: translateX(-50%) translateY(-10px);
        }

        60% {
            transform: translateX(-50%) translateY(-5px);
        }

        }

        media (max-width: 768px) {
            .hero-title

        {
            font-size: 2.5rem;
        }

        .hero-stats {
            flex-direction: column;
            gap: 1.5rem;
        }

        .workflow-line {
            display: none;
        }

        .step-card {
            margin-bottom: 2rem;
        }

        .quick-access-grid {
            grid-template-columns: 1fr;
        }

        }
    </style>
</head>
<body>
    <!-- Floating Background Elements -->
    <div class="floating-elements">
        <div class="floating-circle"></div>
        <div class="floating-circle"></div>
        <div class="floating-circle"></div>
    </div>

    <!-- Hero Section -->
    <section class="hero-section">
        <div class="container">
            <div class="hero-content text-center">
                <h1 class="hero-title">
                    <i class="bi bi-calendar-check-fill me-3"></i>
                    EventEase Management
                </h1>
                <p class="hero-subtitle">
                    Transform your event planning experience with our comprehensive management platform.
                    Streamline venues, events, and bookings in one powerful solution.
                </p>

                <div class="hero-stats">
                    <div class="stat-item">
                        <span class="stat-number">3</span>
                        <span class="stat-label">Core Modules</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-number">∞</span>
                        <span class="stat-label">Possibilities</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-number">1</span>
                        <span class="stat-label">Platform</span>
                    </div>
                </div>
            </div>

            <div class="scroll-indicator">
                <i class="bi bi-chevron-down" style="font-size: 1.5rem;"></i>
            </div>
        </div>
    </section>

    <!-- Workflow Section -->
    <section class="workflow-section">
        <div class="container">
            <div class="section-header">
                <h2 class="section-title">Your Event Management Journey</h2>
                <p class="section-subtitle">
                    Follow our intuitive three-step process to create memorable events.
                    Each step builds upon the previous one, ensuring a seamless experience from start to finish.
                </p>
            </div>

            <div class="workflow-container">
                <div class="workflow-line d-none d-md-block"></div>

                <div class="row g-4">
                    <div class="col-lg-4">
                        <div class="step-card text-center" data-step="1">
                            <div class="step-number">1</div>
                            <h3 class="step-title">
                                <i class="bi bi-building me-2"></i>
                                Venue Setup
                            </h3>
                            <p class="step-description">
                                Begin by registering your venues with detailed information, capacity, and amenities.
                                Create a foundation for all your future events.
                            </p>
                            <a asp-controller="Venues" asp-action="Create" class="step-action">
                                <i class="bi bi-plus-circle-fill"></i>
                                Add Venue
                            </a>
                        </div>
                    </div>

                    <div class="col-lg-4">
                        <div class="step-card text-center" data-step="2">
                            <div class="step-number">2</div>
                            <h3 class="step-title">
                                <i class="bi bi-calendar-event me-2"></i>
                                Event Creation
                            </h3>
                            <p class="step-description">
                                Design and configure your events with comprehensive details, schedules, and requirements.
                                Bring your vision to life with powerful planning tools.
                            </p>
                            <a asp-controller="Events" asp-action="Create" class="step-action">
                                <i class="bi bi-stars"></i>
                                Create Event
                            </a>
                        </div>
                    </div>

                    <div class="col-lg-4">
                        <div class="step-card text-center" data-step="3">
                            <div class="step-number">3</div>
                            <h3 class="step-title">
                                <i class="bi bi-journal-check me-2"></i>
                                Booking Management
                            </h3>
                            <p class="step-description">
                                Connect events with venues through smart booking management.
                                Track reservations, manage schedules, and ensure smooth operations.
                            </p>
                            <a asp-controller="Bookings" asp-action="Create" class="step-action">
                                <i class="bi bi-check2-circle"></i>
                                Make Booking
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Quick Access Section -->
    <section class="quick-access-section">
        <div class="container">
            <div class="quick-access-panel">
                <div class="text-center mb-4">
                    <h3 class="fw-bold mb-3">
                        <i class="bi bi-lightning-charge-fill me-2" style="color: #3b82f6;"></i>
                        Quick Access Dashboard
                    </h3>
                    <p class="text-muted mb-0">
                        Jump directly to any management section and access your data instantly
                    </p>
                </div>

                <div class="quick-access-grid">
                    <a asp-controller="Venues" asp-action="Index" class="quick-access-btn">
                        <i class="bi bi-building quick-access-icon"></i>
                        <span>Manage Venues</span>
                        <small class="text-muted">View & Edit Locations</small>
                    </a>

                    <a asp-controller="Events" asp-action="Index" class="quick-access-btn">
                        <i class="bi bi-calendar-event quick-access-icon"></i>
                        <span>Manage Events</span>
                        <small class="text-muted">Plan & Organize</small>
                    </a>

                    <a asp-controller="Bookings" asp-action="Index" class="quick-access-btn">
                        <i class="bi bi-journal-check quick-access-icon"></i>
                        <span>Manage Bookings</span>
                        <small class="text-muted">Track Reservations</small>
                    </a>
                </div>
            </div>
        </div>
    </section>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Animate step cards on scroll
            const observerOptions = {
                threshold: 0.1,
                rootMargin: '0px 0px -50px 0px'
            };

            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.style.opacity = '1';
                        entry.target.style.transform = 'translateY(0)';
                    }
                });
            }, observerOptions);

            // Initialize step cards
            const stepCards = document.querySelectorAll('.step-card');
            stepCards.forEach((card, index) => {
                card.style.opacity = '0';
                card.style.transform = 'translateY(30px)';
                card.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
                card.style.transitionDelay = `${index * 0.2}s`;
                observer.observe(card);
            });

            // Enhanced workflow validation with better UX
            // const bookingLink = document.querySelector('a[href*="Bookings/Create"]');
            // if (bookingLink) {
            //     bookingLink.addEventListener('click', function(e) {
            //         // Check if events exist (simplified version - you would implement this API endpoint)
            //         const hasEvents = document.querySelector('.step-card[data-step="2"]');
            //         if (hasEvents && !hasEvents.classList.contains('completed')) {
            //             e.preventDefault();

            //             if (confirm('💡 Pro tip: Create events first to make bookings more meaningful! Would you like to create an event now?')) {
            //                 window.location.href = '/Events/Create';
            //             }
            //         }
            //     });
            // }

            // Smooth scroll for scroll indicator
            const scrollIndicator = document.querySelector('.scroll-indicator');
            if (scrollIndicator) {
                scrollIndicator.addEventListener('click', function() {
                    document.querySelector('.workflow-section').scrollIntoView({
                        behavior: 'smooth'
                    });
                });
            }

            // Add dynamic stats counter animation
            const statNumbers = document.querySelectorAll('.stat-number');
            statNumbers.forEach(stat => {
                const finalValue = stat.textContent;
                if (finalValue !== '∞') {
                    let currentValue = 0;
                    const increment = finalValue / 20;
                    const timer = setInterval(() => {
                        currentValue += increment;
                        if (currentValue >= finalValue) {
                            stat.textContent = finalValue;
                            clearInterval(timer);
                        } else {
                            stat.textContent = Math.floor(currentValue);
                        }
                    }, 100);
                }
            });
        });
    </script>
</body>
</html>