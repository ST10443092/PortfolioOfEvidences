@model IEnumerable<CLDV1.Models.Event>

@{
    ViewData["Title"] = "Events";
}

<!-- Bootstrap & Icons -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />

<style>
    body {
        background-color: #f8f9fc;
        font-family: 'Segoe UI', sans-serif;
    }

    .portal-header {
        background: linear-gradient(135deg, #4361ee, #3f37c9);
        color: white;
        padding: 2rem 0;
        border-radius: 0 0 1rem 1rem;
        margin-bottom: 2rem;
        text-align: center;
    }

    .card-custom {
        background-color: #ffffff;
        padding: 2rem;
        border-radius: 1rem;
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.05);
        animation: fadeIn 0.5s ease;
    }

    fadeIn {
        from

    {
        opacity: 0;
        transform: translateY(20px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }

    .table th {
        background-color: #f1f3f5;
        font-weight: 600;
    }

    .btn-primary {
        background-color: #4361ee;
        border-color: #4361ee;
    }

        .btn-primary:hover {
            background-color: #364fc7;
            border-color: #364fc7;
        }

    .btn-outline-primary:hover,
    .btn-outline-info:hover,
    .btn-outline-danger:hover {
        opacity: 0.85;
    }

    .img-thumbnail {
        border-radius: 0.5rem;
        border: 1px solid #dee2e6;
    }
</style>

<div class="portal-header">
    <h1 class="display-6 fw-bold">All Events</h1>
    <p class="lead mb-0">Browse and manage your scheduled events</p>
</div>

<div class="container">
    <div class="card-custom mb-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="mb-0">Event Listings</h4>
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-lg me-1"></i>Create New Event
            </a>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Event Name</th>
                        <th>Date</th>
                        <th>Description</th>
                        <th>Venue</th>
                        <th>Venue Image</th>
                        <th style="width: 160px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.EventName</td>
                            <td>@item.EventDate.ToString("yyyy-MM-dd")</td>
                            <td>@item.Description</td>
                            <td>@item.Venue?.Name</td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.Venue?.ImageUrl))
                                {
                                    <img src="@item.Venue.ImageUrl" alt="Venue Image"
                                         style="max-width: 80px; max-height: 80px;" class="img-thumbnail" />
                                }
                                else
                                {
                                    <span class="text-muted">No Image</span>
                                }
                            </td>
                            <td>
                                <div class="btn-group" role="group">
                                    <a asp-action="Edit" asp-route-id="@item.EventId"
                                       class="btn btn-sm btn-outline-primary" title="Edit">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <a asp-action="Details" asp-route-id="@item.EventId"
                                       class="btn btn-sm btn-outline-info" title="Details">
                                        <i class="bi bi-info-circle"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.EventId"
                                       class="btn btn-sm btn-outline-danger" title="Delete">
                                        <i class="bi bi-trash3"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="mt-3 text-end">
            <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-house me-1"></i>Done
            </a>
        </div>
    </div>
</div>
