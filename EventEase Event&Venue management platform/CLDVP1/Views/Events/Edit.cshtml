@model CLDV1.Models.Event

@{
    ViewData["Title"] = "Edit Event";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

<style>
    .venue-image-preview {
        max-width: 200px;
        max-height: 200px;
        border-radius: 0.5rem;
        border: 1px solid #dee2e6;
    }

    .gradient-header {
        background: linear-gradient(135deg, #4361ee, #3f37c9);
        color: white;
    }
</style>

<div class="container py-4">
    <div class="gradient-header rounded-3 p-4 mb-4 text-center">
        <h1>Edit Event</h1>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-body">
                    <form asp-action="Edit" enctype="multipart/form-data">
                        <input type="hidden" asp-for="EventId" />

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="EventName" class="form-label"></label>
                                    <input asp-for="EventName" class="form-control" />
                                    <span asp-validation-for="EventName" class="text-danger"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="EventDate" class="form-label"></label>
                                    <input asp-for="EventDate" type="datetime-local" class="form-control" />
                                    <span asp-validation-for="EventDate" class="text-danger"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="Description" class="form-label"></label>
                                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                                    <span asp-validation-for="Description" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="VenueId" class="form-label"></label>
                                    <select asp-for="VenueId" class="form-select" asp-items="ViewBag.VenueId"></select>
                                    <span asp-validation-for="VenueId" class="text-danger"></span>
                                </div>
                                <div class="mb-3">
                                    <label asp-for="EventTypeId" class="form-label">Event Type</label>
                                    <select asp-for="EventTypeId" class="form-control" asp-items="ViewBag.EventTypes">
                                        <option value="">-- Select event type --</option>
                                    </select>
                                    <span asp-validation-for="EventTypeId" class="text-danger small"></span>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">Venue Image</label>
                                    @if (!string.IsNullOrEmpty(Model.Venue?.ImageUrl))
                                    {
                                        <img src="@Model.Venue.ImageUrl" class="venue-image-preview d-block mb-2" />
                                    }
                                 
                                </div>
                            </div>
                        </div>

                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-save"></i> Save Changes
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left"></i> Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}