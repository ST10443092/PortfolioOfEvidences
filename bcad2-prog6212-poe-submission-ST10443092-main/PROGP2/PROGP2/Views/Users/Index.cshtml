@model IEnumerable<PROGP2.Models.User>

@{
    ViewData["Title"] = "Users Management";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 fw-bold text-primary">Users Management</h1>
            <p class="text-muted mb-0">Review and manage system users</p>
        </div>
        <a class="btn btn-primary btn-lg px-4" asp-action="Create">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi bi-person-plus me-2" viewBox="0 0 16 16">
                <path d="M6 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6z" />
                <path d="M11 5.5a.5.5 0 0 1 .5-.5H13V3.5a.5.5 0 0 1 1 0V5h1.5a.5.5 0 0 1 0 1H14v1.5a.5.5 0 0 1-1 0V6h-1.5a.5.5 0 0 1-.5-.5z" />
                <path d="M1 14s-1 0-1-1 1-4 6-4 6 3 6 4-1 1-1 1H1zm6-4c-4 0-5 2.686-5 3h10c0-.314-1-3-5-3z" />
            </svg>
            Create User
        </a>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white py-3 border-0">
            <h5 class="card-title mb-0 fw-bold text-primary">All Users</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">@Html.DisplayNameFor(model => model.First().UserName)</th>
                            <th>@Html.DisplayNameFor(model => model.First().Role)</th>
                            <th>@Html.DisplayNameFor(model => model.First().Name)</th>
                            <th class="text-center">Report</th>
                            <th class="text-center">Actions</th>

                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr class="align-middle">
                                <td class="ps-4 fw-semibold">@Html.DisplayFor(modelItem => item.UserName)</td>
                                <td>
                                    <span class="badge rounded-pill @(item.Role == "Admin" ? "bg-danger" : item.Role == "Manager" ? "bg-info" : item.Role == "HR" ? "bg-primary" : "bg-secondary")">@item.Role</span>
                                </td>
                                <td>@Html.DisplayFor(modelItem => item.Name)</td>

                                <td class="text-center">
                                    @{
                                        var currentRole = Context.Session.GetString("Role");
                                    }
                                    @if (string.Equals(currentRole, "HR", StringComparison.OrdinalIgnoreCase) && string.Equals(item.Role, "Employee", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <a asp-action="Report" asp-route-id="@item.UserID" class="btn btn-sm btn-primary" title="Generate Report">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-file-earmark-text" viewBox="0 0 16 16">
                                                <path d="M5 8a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5A.5.5 0 0 1 5 8zm0 2a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5A.5.5 0 0 1 5 10zm0-4a.5.5 0 0 1 .5-.5h2a.5.5 0 0 1 0 1h-2A.5.5 0 0 1 5 6z" />
                                                <path d="M14 4.5V14a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V2a2 2 0 0 1 2-2h5.5L14 4.5zM9.5 3V0H4a1 1 0 0 0-1 1v13a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V5h-3.5A1.5 1.5 0 0 1 9.5 3z" />
                                            </svg>
                                            Generate Report
                                        </a>
                                    }
                                </td>

                                <td>
                                    <div class="d-flex justify-content-center gap-2">
                                        <a asp-action="Details" asp-route-id="@item.UserID" class="btn btn-sm btn-outline-primary" title="View User">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-eye" viewBox="0 0 16 16">
                                                <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8z" />
                                                <path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5z" />
                                            </svg>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.UserID" class="btn btn-sm btn-outline-warning" title="Edit User">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-pencil" viewBox="0 0 16 16">
                                                <path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10-.5.5-3.5 1 1-3.5.5-.5 10-10z" />
                                            </svg>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.UserID" class="btn btn-sm btn-outline-danger" title="Delete User">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-trash" viewBox="0 0 16 16">
                                                <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5Zm2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5Zm3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0V6Z" />
                                                <path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5A1 1 0 0 1 1 3V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5A1 1 0 0 1 15 2v1Z" />
                                            </svg>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
