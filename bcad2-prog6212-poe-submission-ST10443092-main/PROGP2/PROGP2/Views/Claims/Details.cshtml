@model PROGP2.Models.Claim

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

@if (TempData["Message"] != null)
{
    <div class="alert alert-info">@TempData["Message"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div>
    <h4>Claim</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Hours)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Hours)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Rate)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Rate)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Total)
        </dt>
        <dd class="col-sm-10">
            R @Model.Total.ToString("N2")
        </dd>

        <dt class="col-sm-2">
            Rate PDF
        </dt>
        <dd class="col-sm-10">
            <a class="btn btn-sm btn-secondary" asp-action="DownloadPdf" asp-route-id="@Model.ID">
                Download PDF
            </a>
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Status)
        </dt>
        <dd class="col-sm-10">
            <span class="badge
                @(Model.Status == "Approved" ? "bg-success" :
                                    Model.Status == "Verified" ? "bg-info" :
                                    Model.Status == "Declined" ? "bg-danger" : "bg-warning text-dark")">
                @Html.DisplayFor(model => model.Status)
            </span>
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.User)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.User.Name)
        </dd>
    </dl>
</div>

<div class="mt-3">
    @{
        var role = Context.Session.GetString("Role");
    }
    
    @if (role == "Coordinator")
    {
        <!-- Coordinator Actions -->
        @if (Model.Status == "Pending")
        {
            <form asp-action="Verify" method="post" style="display:inline;">
                <input type="hidden" name="id" value="@Model.ID" />
                <button type="submit" class="btn btn-success">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-check-circle me-1" viewBox="0 0 16 16">
                        <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z" />
                        <path d="M10.97 4.97a.235.235 0 0 0-.02.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-1.071-1.05z" />
                    </svg>
                    Verify Claim
                </button>
            </form>
        }
        
        @if (Model.Status == "Pending" || Model.Status == "Verified")
        {
            <form asp-action="Decline" method="post" style="display:inline;">
                <input type="hidden" name="id" value="@Model.ID" />
                <button type="submit" class="btn btn-danger">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-x-circle me-1" viewBox="0 0 16 16">
                        <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z" />
                        <path d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708z" />
                    </svg>
                    Decline Claim
                </button>
            </form>
        }
        
        @if (Model.Status == "Declined")
        {
            <form asp-action="Decline" method="post" style="display:inline;">
                <input type="hidden" name="id" value="@Model.ID" />
                <button type="submit" class="btn btn-warning">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-arrow-counterclockwise me-1" viewBox="0 0 16 16">
                        <path fill-rule="evenodd" d="M8 3a5 5 0 1 1-4.546 2.914.5.5 0 0 0-.908-.417A6 6 0 1 0 8 2v1z" />
                        <path d="M8 4.466V.534a.25.25 0 0 0-.41-.192L5.23 2.308a.25.25 0 0 0 0 .384l2.36 1.966a.25.25 0 0 0 .41-.192z" />
                    </svg>
                    Revert to Pending
                </button>
            </form>
        }
        
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    }
    else if (role == "Manager")
    {
        <!-- Manager Actions -->
        @if (Model.Status == "Verified")
        {
            <form asp-action="Approve" method="post" style="display:inline;">
                <input type="hidden" name="id" value="@Model.ID" />
                <button type="submit" class="btn btn-success">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-check-circle me-1" viewBox="0 0 16 16">
                        <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z" />
                        <path d="M10.97 4.97a.235.235 0 0 0-.02.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-1.071-1.05z" />
                    </svg>
                    Approve Claim
                </button>
            </form>
        }
        
        @if (Model.Status == "Verified")
        {
            <form asp-action="Decline" method="post" style="display:inline;">
                <input type="hidden" name="id" value="@Model.ID" />
                <button type="submit" class="btn btn-danger">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-x-circle me-1" viewBox="0 0 16 16">
                        <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z" />
                        <path d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708z" />
                    </svg>
                    Decline Claim
                </button>
            </form>
        }
        
        @if (Model.Status == "Declined")
        {
            <form asp-action="Decline" method="post" style="display:inline;">
                <input type="hidden" name="id" value="@Model.ID" />
                <button type="submit" class="btn btn-warning">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-arrow-counterclockwise me-1" viewBox="0 0 16 16">
                        <path fill-rule="evenodd" d="M8 3a5 5 0 1 1-4.546 2.914.5.5 0 0 0-.908-.417A6 6 0 1 0 8 2v1z" />
                        <path d="M8 4.466V.534a.25.25 0 0 0-.41-.192L5.23 2.308a.25.25 0 0 0 0 .384l2.36 1.966a.25.25 0 0 0 .41-.192z" />
                    </svg>
                    Revert to Pending
                </button>
            </form>
        }
        
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    }
    else
    {
        <!-- Employee Actions - View Only -->
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    }
</div>
